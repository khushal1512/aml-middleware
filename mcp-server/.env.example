# WebSocket server URL (the main mempool server)
MEMPOOL_WS_URL=ws://localhost:8080

# MCP server settings
MCP_SERVER_NAME=btc-forensics-mcp
MCP_SERVER_VERSION=1.0.0

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Maximum transactions to retain in memory
MAX_TX_STORE=5000

# Risk thresholds
RISK_THRESHOLD_HIGH=75
RISK_THRESHOLD_MEDIUM=40